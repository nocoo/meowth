{
  "name": "@meowth/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "biome check --error-on-warnings src",
    "fmt:check": "biome format src",
    "fmt": "biome format --write src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:cover": "vitest run --coverage",
    "clean": "rm -rf .turbo dist"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "2.1.9",
    "typescript": "^5.7.2",
    "vitest": "2.1.9"
  }
}
