{
  "name": "meowth",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "daemon:build": "cd daemon && go build ./...",
    "daemon:vet": "cd daemon && go vet ./...",
    "daemon:fmt:check": "cd daemon && test -z \"$(gofmt -l .)\" || (gofmt -l . && echo 'gofmt: files above are not formatted; run gofmt -w' >&2; exit 1)",
    "daemon:lint": "cd daemon && go run github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.12.2 run",
    "daemon:g1": "pnpm daemon:fmt:check && pnpm daemon:vet && pnpm daemon:lint",
    "daemon:test": "cd daemon && go test ./... -count=1 -parallel=1",
    "daemon:test:cover": "cd daemon && go test ./... -count=1 -parallel=1 -coverprofile=coverage.out -covermode=count",
    "daemon:cover:report": "cd daemon && go tool cover -func=coverage.out | tail -1",
    "daemon:cover:check": "bash scripts/check-daemon-coverage.sh",
    "dashboard:fmt:check": "pnpm --filter @meowth/dashboard --filter @meowth/shared fmt:check",
    "dashboard:lint": "pnpm --filter @meowth/dashboard --filter @meowth/shared lint",
    "dashboard:typecheck": "pnpm --filter @meowth/dashboard --filter @meowth/shared typecheck",
    "dashboard:test": "pnpm --filter @meowth/dashboard --filter @meowth/shared test:run",
    "dashboard:test:cover": "pnpm --filter @meowth/dashboard --filter @meowth/shared test:cover",
    "dashboard:g1": "pnpm dashboard:fmt:check && pnpm dashboard:lint && pnpm dashboard:typecheck",
    "test:l2": "tsx scripts/run-l2.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "{apps,packages}/**/*.{ts,tsx}": ["biome check --write --error-on-warnings"],
    "daemon/**/*.go": ["gofmt -w"]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "husky": "9.1.7",
    "lint-staged": "15.5.2",
    "tsx": "4.22.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
